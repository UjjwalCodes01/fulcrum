# ================================
# 🚨 COPY THIS TO .env AND FILL IN VALUES
# 🚨 NEVER COMMIT .env TO GIT!
# ================================

# ================================
# AUTH0 - CORE
# ================================
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your_client_id
AUTH0_CLIENT_SECRET=your_client_secret
AUTH0_AUDIENCE=https://fulcrum-api
AUTH0_BASE_URL=http://localhost:3000
AUTH0_ISSUER_BASE_URL=https://your-tenant.us.auth0.com
AUTH0_SECRET=generate_with_openssl_rand_base64_32

# ================================
# AUTH0 - TOKEN VAULT (Resource Server Client)
# Create a "Custom API Client" app type in Auth0
# ================================
AUTH0_TOKEN_VAULT_CLIENT_ID=your_token_vault_client_id
AUTH0_TOKEN_VAULT_CLIENT_SECRET=your_token_vault_client_secret

# ================================
# AUTH0 - M2M (Machine-to-Machine)
# Create a separate M2M app in Auth0 dashboard
# Authorize for Management API with read:users scope
# ================================
AUTH0_MGMT_CLIENT_ID=your_m2m_client_id
AUTH0_MGMT_CLIENT_SECRET=your_m2m_client_secret

# ================================
# AUTH0 - FGA (Fine-Grained Authorization)
# Set up at: https://dashboard.fga.dev/
# ================================
AUTH0_FGA_STORE_ID=your_fga_store_id
AUTH0_FGA_MODEL_ID=your_fga_model_id
AUTH0_FGA_API_URL=https://api.us1.fga.dev

# ================================
# GOOGLE CLOUD
# ================================
GCP_PROJECT_ID=your_gcp_project_id
GCP_REGION=us-central1
VERTEX_AI_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# ================================
# DATABASE (Cloud SQL - PostgreSQL)
# ================================
# Local development:
DATABASE_URL=postgresql://postgres:password@localhost:5432/fulcrum

# Production (Cloud Run):
# DATABASE_URL=postgresql://fulcrum_user:PASSWORD@/fulcrum?host=/cloudsql/PROJECT:REGION:INSTANCE

# ================================
# PUB/SUB (for CIBA async flow)
# ================================
PUBSUB_TOPIC_CIBA=fulcrum-ciba-events
PUBSUB_SUBSCRIPTION_CIBA=fulcrum-ciba-sub

# ================================
# COST PROTECTION (IMPORTANT!)
# ================================
MAX_DAILY_VERTEX_REQUESTS=50
MAX_INPUT_LENGTH=5000
RATE_LIMIT_PER_USER=100
ALERT_THRESHOLD_USD=45

# ================================
# APP
# ================================
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
